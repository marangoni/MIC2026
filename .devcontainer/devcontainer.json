{
  "name": "MIC2026 AVR Lab",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Desktop remoto",
      "onAutoForward": "openPreview"
    }
  },
  "postStartCommand": "bash .devcontainer/scripts/start-desktop.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteUser": "vscode"
}
